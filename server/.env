# JWT secret for signing tokens. Use a strong random string in production.
JWT_SECRET=your-super-secret-key-change-in-production

# Demo mode: login without MongoDB (admin@example.com / 123456)
DEMO_MODE=true


VITE_API_BASE_URL=http://localhost:5000

# MongoDB: Use local MongoDB or MongoDB Atlas (free tier at mongodb.com/atlas)
# Leave empty or omit to use local: mongodb://127.0.0.1:27017/roomdesigner
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/roomdesigner?retryWrites=true&w=majority
